{
  "name": "chisinau-queue-bot",
  "version": "1.0.0",
  "description": "Telegram notifier for Passport Service e-queue slots in Chisinau.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check:once": "tsx src/index.ts --once",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "telegram",
    "railway",
    "passport",
    "queue",
    "monitor"
  ],
  "license": "MIT"
}
